<% content_for :title, "パスワード生成機 - ゲストモード" %>
<% content_for :head do %>
  <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;700&display=swap" rel="stylesheet">
<% end %>
<div class="font-display bg-background-dark text-slate-100 min-h-screen flex flex-col items-center justify-center relative overflow-hidden selection:bg-primary/30">
  <!-- Ambient Background -->
  <div class="absolute top-[-10%] left-[-10%] w-[40%] h-[40%] bg-primary/5 rounded-full blur-[120px] pointer-events-none"></div>
  <div class="absolute bottom-[-10%] right-[-10%] w-[40%] h-[40%] bg-primary/5 rounded-full blur-[120px] pointer-events-none"></div>
  <div class="absolute inset-0 ambient-glow pointer-events-none"></div>

  <!-- Top Navigation -->
  <nav class="fixed top-0 w-full px-6 md:px-8 py-6 flex justify-between items-center z-50">
    <div class="flex items-center gap-2">
      <span class="material-icons text-primary text-2xl">lock</span>
      <span class="text-lg font-bold tracking-tight">パスワード生成機</span>
    </div>
    <div class="flex items-center gap-4 md:gap-6">
      <%= link_to "ログイン", new_session_path, class: "text-sm font-medium text-slate-400 hover:text-primary transition-colors" %>
      <%= link_to "アカウント作成", new_users_path, class: "px-4 py-2 rounded-lg bg-primary/10 border border-primary/20 text-primary text-sm font-bold hover:bg-primary/20 transition-all" %>
    </div>
  </nav>

  <!-- Main Content -->
  <main class="w-full max-w-2xl px-4 z-10 flex flex-col items-center" data-controller="guest-generator">
    <!-- Status Indicator -->
    <div class="mb-6 flex items-center gap-2 px-3 py-1.5 rounded-full bg-primary/10 border border-primary/20">
      <span class="relative flex h-2 w-2">
        <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-primary opacity-75"></span>
        <span class="relative inline-flex rounded-full h-2 w-2 bg-primary"></span>
      </span>
      <span class="text-xs font-bold tracking-wider text-primary uppercase">ゲストセッション</span>
    </div>

    <!-- Central Card -->
    <div class="glass-card-guest w-full rounded-xl p-8 md:p-12 shadow-2xl relative overflow-hidden">
      <!-- Password Display -->
      <div class="relative group mb-8">
        <div class="bg-black/40 rounded-lg p-6 md:p-8 border border-slate-800 flex items-center justify-between gap-4 group-hover:border-primary/30 transition-colors">
          <div class="overflow-x-auto min-w-0 flex-1">
            <span class="font-mono text-2xl md:text-4xl text-white tracking-wider break-all leading-tight" data-guest-generator-target="output" style="font-family: 'JetBrains Mono', monospace;"></span>
          </div>
          <div class="flex items-center gap-1 flex-shrink-0">
            <button type="button" class="p-2 text-slate-400 hover:text-primary transition-colors" title="再生成" data-action="click->guest-generator#regenerate" aria-label="再生成">
              <span class="material-icons text-2xl md:text-3xl">refresh</span>
            </button>
            <button type="button" class="p-2 text-slate-400 hover:text-primary transition-colors" title="コピー" data-action="click->guest-generator#copy" aria-label="コピー">
              <span class="material-icons text-xl md:text-2xl" data-guest-generator-target="copyIcon">content_copy</span>
            </button>
          </div>
        </div>
      </div>

      <!-- Settings -->
      <div class="space-y-8">
        <!-- Length Slider -->
        <div class="space-y-4">
          <div class="flex justify-between items-center">
            <label class="text-sm font-bold text-slate-300">パスワードの長さ</label>
            <span class="text-primary font-mono font-bold text-lg" data-guest-generator-target="lengthValue">12</span>
          </div>
          <input type="range" min="6" max="18" value="12" class="w-full h-1.5 bg-slate-800 rounded-lg appearance-none cursor-pointer accent-primary" data-guest-generator-target="lengthSlider" data-action="input->guest-generator#updateLength"/>
          <div class="flex justify-between text-[10px] text-slate-500 font-mono">
            <span>6</span>
            <span>12</span>
            <span>18</span>
          </div>
        </div>

        <!-- Toggles -->
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4">
          <label class="flex items-center justify-between p-3 rounded-lg bg-white/5 border border-slate-800 cursor-pointer hover:bg-white/10 transition-colors">
            <span class="text-sm text-slate-300">数字</span>
            <div class="relative inline-flex items-center cursor-pointer">
              <input type="checkbox" checked class="sr-only peer" data-guest-generator-target="numbers" data-action="change->guest-generator#regenerate"/>
              <div class="w-10 h-5 bg-slate-700 peer-focus:outline-none rounded-full peer peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:border after:rounded-full after:h-4 after:w-4 after:transition-all peer-checked:bg-primary"></div>
            </div>
          </label>
          <label class="flex items-center justify-between p-3 rounded-lg bg-white/5 border border-slate-800 cursor-pointer hover:bg-white/10 transition-colors">
            <span class="text-sm text-slate-300">記号</span>
            <div class="relative inline-flex items-center cursor-pointer">
              <input type="checkbox" checked class="sr-only peer" data-guest-generator-target="symbols" data-action="change->guest-generator#regenerate"/>
              <div class="w-10 h-5 bg-slate-700 peer-focus:outline-none rounded-full peer peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:border after:rounded-full after:h-4 after:w-4 after:transition-all peer-checked:bg-primary"></div>
            </div>
          </label>
          <label class="flex items-center justify-between p-3 rounded-lg bg-white/5 border border-slate-800 cursor-pointer hover:bg-white/10 transition-colors">
            <span class="text-sm text-slate-300">大文字</span>
            <div class="relative inline-flex items-center cursor-pointer">
              <input type="checkbox" checked class="sr-only peer" data-guest-generator-target="uppercase" data-action="change->guest-generator#regenerate"/>
              <div class="w-10 h-5 bg-slate-700 peer-focus:outline-none rounded-full peer peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:border after:rounded-full after:h-4 after:w-4 after:transition-all peer-checked:bg-primary"></div>
            </div>
          </label>
          <label class="flex items-center justify-between p-3 rounded-lg bg-white/5 border border-slate-800 cursor-pointer hover:bg-white/10 transition-colors">
            <span class="text-sm text-slate-300">小文字</span>
            <div class="relative inline-flex items-center cursor-pointer">
              <input type="checkbox" checked class="sr-only peer" data-guest-generator-target="lowercase" data-action="change->guest-generator#regenerate"/>
              <div class="w-10 h-5 bg-slate-700 peer-focus:outline-none rounded-full peer peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:border after:rounded-full after:h-4 after:w-4 after:transition-all peer-checked:bg-primary"></div>
            </div>
          </label>
        </div>
      </div>

      <!-- Secondary Info -->
      <p class="mt-8 text-slate-500 text-sm">
        より高度な管理が必要ですか？ <%= link_to "パスワードマネージャーを試す", new_session_path, class: "text-primary hover:underline" %>
      </p>
    </div>
  </main>

  <!-- Fixed Bottom Warning -->
  <footer class="fixed bottom-0 w-full py-4 bg-background-dark/80 backdrop-blur-md border-t border-slate-800/50 flex justify-center items-center z-50">
    <div class="flex items-center gap-2 text-slate-400 text-xs md:text-sm tracking-wide">
      <span class="material-icons text-amber-500 text-base">warning</span>
      ゲストモードではデータは保存されません
    </div>
  </footer>
</div>
