<% active_nav = local_assigns[:active_nav] || :dashboard %>
<aside class="relative z-20 w-72 flex-shrink-0 flex flex-col bg-card-dark/50 border-r border-white/5 h-screen sticky top-0">
  <div class="p-6 flex items-center gap-3">
    <div class="w-10 h-10 rounded-lg bg-gradient-to-br from-primary to-accent-purple flex items-center justify-center">
    </div>
    <div>
      <h1 class="text-xl font-black tracking-tight text-white">CyberVault</h1>
      <p class="text-[10px] uppercase tracking-widest text-primary font-bold">Security Protocol</p>
    </div>
  </div>
  <nav class="flex-1 px-4 py-6 space-y-2">
    <%= link_to passwords_path, class: (active_nav == :dashboard ? "flex items-center gap-3 px-4 py-3 bg-primary/10 text-primary border border-primary/20 rounded-lg no-underline" : "flex items-center gap-3 px-4 py-3 text-slate-400 hover:text-primary transition-colors rounded-lg no-underline") do %>
      <span class="material-icons">dashboard</span>
      <span class="text-sm font-medium">ダッシュボード</span>
    <% end %>
    <%= link_to new_password_path, class: (active_nav == :password_new ? "flex items-center gap-3 px-4 py-3 bg-primary/10 text-primary border border-primary/20 rounded-lg no-underline" : "flex items-center gap-3 px-4 py-3 text-slate-400 hover:text-primary transition-colors rounded-lg no-underline") do %>
      <span class="material-icons">key</span>
      <span class="text-sm font-medium">パスワード生成</span>
    <% end %>
  </nav>
  <div class="p-6 border-t border-white/5">
    <div class="flex items-center gap-4 mb-4">
      <div class="w-10 h-10 rounded-full border-2 border-white/10 bg-white/5 flex items-center justify-center overflow-hidden flex-shrink-0">
        <span class="material-icons text-slate-400 text-xl">person</span>
      </div>
      <div class="flex-1 min-w-0">
        <p class="text-xs text-slate-500 font-bold uppercase tracking-wider">User</p>
        <p class="text-sm text-white font-medium truncate"><%= @user&.email %></p>
      </div>
    </div>
    <%= button_to session_path, method: :delete, class: "w-full flex items-center justify-center gap-2 py-2 px-4 rounded-lg bg-slate-800 hover:bg-slate-700 transition-colors text-sm font-bold text-slate-200 no-underline", form: { class: "w-full" } do %>
      <span class="material-icons text-sm">logout</span>
      ログアウト
    <% end %>
  </div>
</aside>
