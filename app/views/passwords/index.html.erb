<% content_for :title, "ダッシュボード - CyberVault" %>
<%= render layout: "shared/cybervault_app_layout", locals: {
  active_nav: :dashboard,
  page_title: "ダッシュボード",
  page_subtitle: "保存したパスワードの一覧とセキュリティ概要",
  header_variant: :dashboard
} do %>
  <section class="px-10 pb-20 flex-1 z-10">
    <div class="max-w-4xl mx-auto space-y-8">
      <!-- Summary Cards -->
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        <div class="glass-panel p-6 rounded-xl border-l-4 border-emerald-400">
          <div class="flex justify-between items-start mb-4">
            <p class="text-slate-400 text-sm font-medium">安全な強度</p>
            <span class="material-icons text-emerald-400">check_circle</span>
          </div>
          <div class="flex items-baseline gap-2">
            <h3 class="text-3xl font-bold text-white"><%= @safe_count %></h3>
            <span class="text-xs text-emerald-400">良好</span>
          </div>
        </div>
        <div class="glass-panel p-6 rounded-xl border-l-4 border-yellow-400">
          <div class="flex justify-between items-start mb-4">
            <p class="text-slate-400 text-sm font-medium">脆弱なパスワード</p>
            <span class="material-icons text-yellow-400">warning</span>
          </div>
          <div class="flex items-baseline gap-2">
            <h3 class="text-3xl font-bold text-white"><%= @weak_count %></h3>
            <span class="text-xs text-yellow-400">要修正</span>
          </div>
        </div>
      </div>

      <% if @passwords.present? %>
        <div class="glass-panel rounded-xl overflow-hidden flex flex-col">
          <div class="p-6 border-b border-white/10 flex justify-between items-center">
            <h3 class="text-xl font-bold text-white">保存したパスワード</h3>
          </div>
          <div class="overflow-x-auto">
            <table class="w-full text-left">
              <thead class="text-xs text-slate-500 uppercase bg-white/5">
                <tr>
                  <th class="px-6 py-4 font-medium">ウェブサイトURL</th>
                  <th class="px-6 py-4 font-medium">ユーザー名</th>
                  <th class="px-6 py-4 font-medium">更新日</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-white/5">
                <% @passwords.each do |pwd| %>
                  <tr
                    role="button"
                    tabindex="0"
                    class="hover:bg-white/5 transition-colors cursor-pointer <%= 'bg-yellow-500/5' if pwd.entropy_bits == 1 %>"
                    data-password-row-url-value="<%= password_path(pwd) %>"
                    data-action="click->password-row#navigate keydown.enter->password-row#navigate"
                    data-controller="password-row"
                    aria-label="<%= pwd.website_url.presence || 'パスワード' %>の詳細を表示"
                  >
                    <td class="px-6 py-4">
                      <div class="flex items-center gap-3">
                        <div class="w-8 h-8 rounded bg-white/20 flex items-center justify-center flex-shrink-0">
                          <span class="text-white text-xs font-bold"><%= (pwd.website_url.to_s)[0]&.upcase || "?" %></span>
                        </div>
                        <span class="font-medium text-white truncate max-w-[200px]"><%= pwd.website_url.presence || "—" %></span>
                        <% if pwd.entropy_bits == 1 %>
                          <span class="material-icons text-yellow-400 text-lg flex-shrink-0" title="脆弱なパスワード">warning</span>
                        <% end %>
                      </div>
                    </td>
                    <td class="px-6 py-4 text-slate-300"><%= pwd.username.presence || "—" %></td>
                    <td class="px-6 py-4 text-slate-400 text-sm"><%= pwd.updated_at&.strftime("%Y/%m/%d") %></td>
                  </tr>
                <% end %>
              </tbody>
            </table>
          </div>
          <% if @weak_count.positive? %>
            <div class="p-6 mt-auto border-t border-white/5">
              <div class="p-4 rounded-lg flex items-center gap-3 border border-yellow-500/30 bg-yellow-500/10">
                <span class="material-icons text-yellow-400 text-2xl">warning</span>
                <div>
                  <p class="text-sm font-bold text-white">セキュリティ強度が低いパスワードがあります</p>
                  <p class="text-xs text-slate-400"><%= @weak_count %>件のパスワードの強度が不足しています。パスワード生成で長さ・文字種を増やして再保存することを推奨します。</p>
                </div>
              </div>
            </div>
          <% end %>
        </div>
      <% else %>
        <div class="glass-panel p-8 rounded-xl text-center">
          <span class="material-icons text-slate-500 text-5xl mb-4">lock_open</span>
          <p class="text-slate-400 mb-6">まだパスワードを保存していません</p>
          <%= link_to new_password_path, class: "glow-button inline-flex items-center gap-2 bg-primary text-background-dark font-bold py-3 px-6 rounded-lg no-underline" do %>
            <span class="material-icons">add</span>
            パスワードを生成して保存
          <% end %>
        </div>
      <% end %>
    </div>
  </section>
<% end %>
