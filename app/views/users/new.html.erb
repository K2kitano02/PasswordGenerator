<div class="font-display min-h-screen flex items-center justify-center overflow-hidden relative bg-background-dark text-slate-100">
  <div class="absolute top-[-10%] left-[-10%] w-[50%] h-[50%] bg-orb-cyan rounded-full pointer-events-none"></div>
  <div class="absolute bottom-[-10%] right-[-10%] w-[50%] h-[50%] bg-orb-purple rounded-full pointer-events-none"></div>
  <div class="absolute inset-0 opacity-[0.03] pointer-events-none bg-grid-dots"></div>

  <main class="relative z-10 w-full max-w-[450px] px-6 py-8 pt-12">
    <div class="flex flex-col items-center mb-8 text-center">
      <div class="w-16 h-16 bg-primary/10 rounded-xl flex items-center justify-center mb-4 border border-primary/30">
        <span class="material-icons text-primary text-4xl">vps_guard</span>
      </div>
      <h1 class="text-3xl font-bold tracking-tight text-white uppercase">CYBER<span class="text-primary">VAULT</span></h1>
      <p class="text-slate-400 mt-2 text-sm tracking-widest">次世代バイオメトリック・セキュリティ</p>
    </div>

    <div class="glass-card rounded-xl p-8 shadow-2xl">
      <h2 class="text-xl font-bold mb-6 text-white text-center">新規登録</h2>

      <%= render "shared/object_errors", object: @user %>

      <%= form_with model: @user, url: users_path, local: true, class: "space-y-6" do |f| %>
        <div class="space-y-2">
          <label class="auth-label" for="user_email">メールアドレス</label>
          <div class="auth-field-wrapper relative group neon-shadow rounded-lg">
            <div class="auth-input-icon-wrapper absolute inset-y-0 left-0 flex items-center pointer-events-none">
              <span class="material-icons auth-input-icon">alternate_email</span>
            </div>
            <%= f.email_field :email, class: "auth-input auth-input-with-icon", placeholder: "example@cybervault.io", id: "user_email" %>
          </div>
        </div>

        <div class="space-y-2">
          <label class="auth-label" for="user_password">パスワード</label>
          <div class="auth-field-wrapper relative group neon-shadow rounded-lg">
            <div class="auth-input-icon-wrapper absolute inset-y-0 left-0 flex items-center pointer-events-none">
              <span class="material-icons auth-input-icon">lock</span>
            </div>
            <%= f.password_field :password, class: "auth-input auth-input-with-icon", placeholder: "6文字以上", id: "user_password" %>
          </div>
        </div>

        <div class="space-y-2">
          <label class="auth-label" for="user_password_confirmation">パスワード（確認）</label>
          <div class="auth-field-wrapper relative group neon-shadow rounded-lg">
            <div class="auth-input-icon-wrapper absolute inset-y-0 left-0 flex items-center pointer-events-none">
              <span class="material-icons auth-input-icon">lock</span>
            </div>
            <%= f.password_field :password_confirmation, class: "auth-input auth-input-with-icon", placeholder: "••••••••", id: "user_password_confirmation" %>
          </div>
        </div>

        <div class="space-y-4 pt-2">
          <button class="glow-button w-full bg-primary text-background-dark font-bold py-3.5 px-4 rounded-lg flex items-center justify-center space-x-2 group" type="submit">
            <span class="tracking-widest">アカウントを作成</span>
            <span class="material-icons text-xl group-hover:translate-x-1 transition-transform">bolt</span>
          </button>
          <%= link_to generator_path, class: "ghost-purple w-full text-accent-purple font-bold py-3.5 px-4 rounded-lg flex items-center justify-center space-x-2 no-underline block" do %>
            <span class="material-icons text-xl">person_search</span>
            <span class="tracking-widest">ゲストとして利用</span>
          <% end %>
        </div>
      <% end %>

      <div class="mt-8 text-center border-t border-white/5 pt-6">
        <p class="text-sm text-slate-400">
          既にアカウントをお持ちですか？
          <%= link_to "ログイン", new_session_path, class: "text-primary font-bold hover:underline underline-offset-4 ml-1" %>
        </p>
      </div>
    </div>

    <%= render "shared/auth_status_footer" %>
  </main>

  <%= render "shared/auth_decorations" %>
</div>
